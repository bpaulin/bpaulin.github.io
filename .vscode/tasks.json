{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Serve",
            "type": "shell",
            "command": "jekyll serve --livereload",
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "options": {
                "env": {
                    "LC_ALL":"C.UTF-8",
                    "LANG":"en_US.UTF-8",
                    "LANGUAGE":"en_US.UTF-8",
                }
            },
            "isBackground": true,
        },
        {
            "label": "Build",
            "type": "shell",
            "command": "bundle exec jekyll build",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "options": {
                "env": {
                    "LC_ALL":"C.UTF-8",
                    "LANG":"en_US.UTF-8",
                    "LANGUAGE":"en_US.UTF-8",
                }
            },
        }
    ]
}
